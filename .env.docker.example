# =============================================================================
# THE Fulfillment — biến môi trường cho STACK DOCKER (production)
#
# File này nạp cho CẢ backend (runtime) và frontend (build-arg). Copy thành
# `.env.docker` rồi điền giá trị thật:
#     cp .env.docker.example .env.docker && chmod 600 .env.docker
#
# Các script trong scripts/ chạy compose với `--env-file .env.docker`, nên đây
# là NGUỒN DUY NHẤT cho toàn stack. KHÔNG commit `.env.docker` (đã .gitignore).
#
# ⚠️ Khác với THE-fulfillment-web/.env (chỉ dùng cho `npm run dev` của FE) —
#    file này dành riêng cho Docker và phải trỏ DB_* tới Supabase.
# =============================================================================

# ---- App --------------------------------------------------------------------
APP_ENV=production
APP_NAME=THE Fulfillment API
# Cổng HTTP NỘI BỘ container. PHẢI là 8080 — Caddy proxy tới backend:8080 và
# healthcheck cũng hit 8080. (Không phải 8090 như .env dev.)
PORT=8080

# ---- Database (Supabase — PostgreSQL managed) -------------------------------
# Lấy từ Supabase → Project Settings → Database → Connection string.
# Khuyến nghị dùng "Direct connection" (cổng 5432) cho GORM AutoMigrate; pooler
# transaction-mode (6543) có thể xung đột prepared statements của pgx.
DB_HOST=db.<project-ref>.supabase.co
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=<mật khẩu database Supabase>
DB_NAME=postgres
# Supabase BẮT BUỘC TLS → require. (disable chỉ dùng cho Postgres nội bộ.)
DB_SSLMODE=require
DB_TIMEZONE=Asia/Ho_Chi_Minh

# Pool — sizing cho VPS nhỏ. Để mặc định là ổn.
DB_MAX_OPEN_CONNS=15
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME_MINUTES=30
DB_CONN_MAX_IDLE_MINUTES=5

# ---- Auth (JWT) -------------------------------------------------------------
# BẮT BUỘC đổi. App TỪ CHỐI boot ở production nếu để mặc định hoặc < 32 ký tự.
#   openssl rand -base64 48
JWT_SECRET=<chuỗi ngẫu nhiên >= 32 ký tự>
JWT_EXPIRES_HOURS=72

# ---- CORS & proxy -----------------------------------------------------------
# Origin của frontend. KHÔNG để "*" ở production.
CORS_ALLOWED_ORIGINS=https://app.domain.com
# Dải mạng của Caddy trong Docker để backend lấy đúng IP client (rate-limit).
# Dùng dải bridge mặc định của compose; xem lại bằng `docker network inspect`.
TRUSTED_PROXIES=172.16.0.0/12

# ---- Seed -------------------------------------------------------------------
SEED_ON_START=true
# false ở production: không tạo tài khoản demo owner@the.local… trong DB thật.
SEED_DEMO_USERS=false
# Chỉ dùng khi SEED_DEMO_USERS=true; phải >= 10 ký tự và khác mặc định.
SEED_DEMO_PASSWORD=<bỏ trống nếu demo off>

# ---- Danger zone / bảo trì --------------------------------------------------
ALLOW_DATA_RESET=false
PURGE_ENABLED=true
PURGE_RETENTION_DAYS=30
PURGE_INTERVAL_HOURS=24

# ---- Timezone container (dấu thời gian log) ---------------------------------
TZ=Asia/Ho_Chi_Minh

# ---- Frontend ---------------------------------------------------------------
# NHÚNG vào bundle client lúc `nuxt build` (app là SPA) → phải là URL API mà
# TRÌNH DUYỆT gọi được (qua Caddy), KHÔNG phải tên service nội bộ.
NUXT_PUBLIC_API_BASE_URL=https://api.domain.com
