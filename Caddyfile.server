# =============================================================================
# Caddyfile.server — PRODUCTION: subdomain + HTTPS (Let's Encrypt tự động)
# Truy cập: https://fulfillment.bacgiangdecor.com
#
# Same-origin: FE gọi /api/* tương đối → không CORS, KHÔNG cần rebuild FE.
# Caddy tự xin cert HTTPS (ACME) khi domain đã trỏ DNS về IP VPS và port 80/443 mở.
# Deploy qua docker-compose.server.yml (CI mount file này làm config Caddy).
# =============================================================================

fulfillment.bacgiangdecor.com {
    encode zstd gzip

    # Cho phép upload file import (Excel/CSV) lớn.
    request_body {
        max_size 25MB
    }

    # --- Backend: giữ nguyên path /api/... và /health ---
    handle /api/* {
        reverse_proxy backend:8080
    }
    handle /health {
        reverse_proxy backend:8080
    }

    # --- Frontend: mọi thứ còn lại ---
    handle {
        reverse_proxy frontend:3000
    }
}
